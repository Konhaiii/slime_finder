{
	"schemaVersion": 1,
	"id": "slime_finder",
	"version": "${version}",
	"name": "Slime Finder",
	"description": "Craft a Slime Dowsing Staff to find slime chunks !",
	"authors": [
		"Konhaiii"
	],
	"contact": {
		"homepage": "https://github.com/Konhaiii/slime_finder",
		"sources": "https://github.com/Konhaiii/slime_finder",
		"issues": "https://github.com/Konhaiii/slime_finder/issues"
	},
	"license": "CC BY-NC 4.0",
	"icon": "assets/slime_finder/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"konhaiii.slime_finder.SlimeFinder"
		],
		"client": [
			"konhaiii.slime_finder.client.SlimeFinderClient"
		]
	},
	"mixins": [
		"slime_finder.mixins.json",
		{
			"config": "slime_finder.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.6",
		"minecraft": "~26.1",
		"java": ">=25",
		"fabric-api": "*"
	}
}